# Environment variables for CARE-AI
# Copy this file to .env and fill in your values

# Application
ENVIRONMENT=development
DEBUG=true

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/careai

# Redis
REDIS_URL=redis://localhost:6379/0

# Firebase (for push notifications)
FIREBASE_CREDENTIALS_PATH=/path/to/firebase-credentials.json

# Security
SECRET_KEY=your-super-secret-key-change-in-production

# ML Models
MODELS_PATH=./models

# Alert Settings
FALL_DETECTION_THRESHOLD=0.7
HEALTH_RISK_ALERT_THRESHOLD=0.6
LONELINESS_ALERT_THRESHOLD=0.7

# Notification Settings
ENABLE_SMS_NOTIFICATIONS=true
ENABLE_CALL_NOTIFICATIONS=true
ENABLE_PUSH_NOTIFICATIONS=true
